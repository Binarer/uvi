# ============================================================
#  UVI — .env.example
# ============================================================
# Скопируйте этот файл в .env и заполните реальными данными.

# ── Database (Postgres) ──────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/uvi
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres_secret

# ── JWT Security ────────────────────────────────────────────
# Сгенерируйте длинный случайный ключ (минимум 32-64 символа)
JWT_SECRET=your-very-long-and-secure-random-secret-key-here
JWT_EXPIRATION_MS=86400000

# ── SMS Aero (SMS Gateway) ──────────────────────────────────
# Режим разработки (true = SMS не отправляются реально)
SMS_DEVELOPMENT_MODE=true
SMS_AERO_EMAIL=your-email@example.com
SMS_AERO_API_KEY=your-aero-api-key-here

# ── MQTT ────────────────────────────────────────────────────
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=uvi-server
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
